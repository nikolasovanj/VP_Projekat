<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<system.serviceModel>

		<client>
			<endpoint name="BatteryService"
					  address="net.tcp://localhost:4002/BatteryLibrary"
					  binding="netTcpBinding"
					  contract="Common.IBattery" />
		</client>

	</system.serviceModel>
</configuration>